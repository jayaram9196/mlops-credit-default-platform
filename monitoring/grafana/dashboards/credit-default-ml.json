{
  "title": "Credit Default API — Model",
  "uid": "credit-default-ml",
  "schemaVersion": 39,
  "timezone": "",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["mlops", "credit-default", "model"],
  "panels": [
    {
      "title": "Predictions / sec by decision",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (decision) (rate(model_predictions_total[5m]))",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "title": "Decision share (last 1h)",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (decision) (increase(model_predictions_total[1h]))",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "title": "Prediction score distribution",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (le) (rate(model_prediction_score_bucket[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "title": "Drift share (latest run)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "credit_default_drift_share_drifted",
          "legendFormat": "share drifted"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.15, "color": "yellow" },
              { "value": 0.30, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Drifted columns over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 16, "w": 16, "h": 6 },
      "targets": [
        {
          "expr": "credit_default_drift_n_drifted",
          "legendFormat": "drifted"
        },
        {
          "expr": "credit_default_drift_n_columns",
          "legendFormat": "total"
        }
      ]
    }
  ]
}
