# Normalise line endings — store LF in the repo, allow OS-native checkout
* text=auto eol=lf

# Always LF (these are read by Linux containers / CI runners)
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.md text eol=lf
Dockerfile* text eol=lf
Jenkinsfile text eol=lf
Makefile text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pkl binary
*.joblib binary
*.h5 binary
*.onnx binary
*.parquet binary
